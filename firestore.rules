rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == "vscvietnamslingshot@gmail.com" ||
        request.auth.token.email == "nahnatofficial@gmail.com"
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2048)) &&
             data.role is string && (data.role == "user" || data.role == "admin");
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      
      allow create: if isEmailVerified() && 
                    userId == request.auth.uid && 
                    isValidUser(incoming()) && 
                    incoming().uid == request.auth.uid &&
                    // Forbid users from assigning themselves admin role
                    (incoming().role == "user" || isAdmin());
                    
      allow update: if isEmailVerified() && 
                    (userId == request.auth.uid || isAdmin()) && 
                    isValidUser(incoming()) &&
                    // Role is an immortal/protected field for standard users
                    (incoming().role == existing().role || isAdmin()) &&
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email;
                    
      allow delete: if isAdmin();
    }

    // --- Tournaments ---
    function isValidTournament(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.matchName is string && data.matchName.size() <= 256 &&
             data.creatorId is string && data.creatorId.size() <= 128 &&
             data.creatorEmail is string && data.creatorEmail.size() <= 256 &&
             data.competitionMode is string && (data.competitionMode == "individual" || data.competitionMode == "team") &&
             data.shotsCount is number && data.shotsCount >= 1 && data.shotsCount <= 200 &&
             data.teamShotsCount is number && data.teamShotsCount >= 0 && data.teamShotsCount <= 200 &&
             (!('referees' in data) || (data.referees is list && data.referees.size() <= 50)) &&
             (!('subAdmins' in data) || (data.subAdmins is list && data.subAdmins.size() <= 50));
    }

    match /tournaments/{tournamentId} {
      allow read: if true; // Public spectators need to access scores & brackets
      
      allow create: if isEmailVerified() && 
                    isValidId(tournamentId) &&
                    isValidTournament(incoming()) && 
                    incoming().creatorId == request.auth.uid;
                    
      allow update: if isEmailVerified() && 
                    isValidId(tournamentId) &&
                    isValidTournament(incoming()) && (
                      isAdmin() ||
                      existing().creatorId == request.auth.uid ||
                      (existing().subAdmins != null && request.auth.token.email in existing().subAdmins) ||
                      (existing().referees != null && request.auth.token.email in existing().referees)
                    ) &&
                    // Immutable fields check
                    incoming().id == existing().id &&
                    incoming().creatorId == existing().creatorId;
                    
      allow delete: if isEmailVerified() && 
                    isValidId(tournamentId) && (
                      isAdmin() ||
                      existing().creatorId == request.auth.uid ||
                      (existing().subAdmins != null && request.auth.token.email in existing().subAdmins)
                    );
    }

    // --- VSC Official System Athletes ---
    function isValidVscSystemAthletes(data) {
      return data.athletes is list && data.athletes.size() <= 5000;
    }

    match /vsc_system_athletes/{documentId} {
      allow read: if true;
      allow write: if isEmailVerified() && isValidId(documentId) && isAdmin() && isValidVscSystemAthletes(incoming());
    }
  }
}
